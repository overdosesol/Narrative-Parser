# ===================================================================
# Catalyst v3.0 — Production Environment Configuration
# ===================================================================
# Скопируй этот файл в .env и заполни нужные значения
# ВАЖНО: Никогда не коммитай .env в Git!
# ===================================================================

# ─── NODE.JS ────────────────────────────────────────────────────

NODE_ENV=production

# ─── TELEGRAM BOT ───────────────────────────────────────────────

# Получить у @BotFather в Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ─── SOLANA PAY ──────────────────────────────────────────────────

# Твой Solana кошелёк для получения платежей
SOLANA_MERCHANT_WALLET=your_solana_wallet_address_here

# Mainnet RPC endpoint (или используй Helius для лучшей скорости)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Helius RPC API ключ (опционально, для ускорения)
HELIUS_API_KEY=your_helius_api_key_here

# ─── TWITTER / X ────────────────────────────────────────────────

# Опционально, для поиска по Twitter/X
# TWITTER_AUTH_TOKEN=твой_токен
# TWITTER_CT0=твой_ct0

# ─── X TRENDS (collector via Apify) ─────────────────────────────
# Pulls live trending topics from X. Distinct from tweet search above —
# this returns the trending hashtags/topics (X's "Trending" tab).
# Cost: ~$0.29 / 1000 results × ~30 trends × 48 runs/day ≈ $13/month.
# Toggle off for zero cost: X_TRENDS_ENABLED=0
X_TRENDS_ENABLED=1
# Refresh interval in minutes — controls Apify call frequency. Default 30
# matches X's real-world trends update cadence. Lower = fresher / pricier.
X_TRENDS_REFRESH_MINUTES=30
# Country to scrape. English priority defaults to United States.
# Other valid values: 'United Kingdom', 'Worldwide', 'Japan', etc.
X_TRENDS_COUNTRY=United States
# Apify actor ID. Default: karamelo/twitter-trends-scraper. Override if you
# switch to a different trends actor (must return same shape: { trend, time,
# timePeriod, volume }).
APIFY_X_TRENDS_ACTOR_ID=karamelo~twitter-trends-scraper
# Optional dedicated Apify token. If empty, falls back to APIFY_API_KEY.
# APIFY_X_TRENDS_KEY=

# ─── AI PROVIDERS ────────────────────────────────────────────────

# xAI (Grok)
XAI_API_KEY=your_xai_api_key_here
XAI_MODEL=grok-4-1-fast-non-reasoning
XAI_BASE_URL=https://api.x.ai/v1

# OpenAI (GPT)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5.4-mini
OPENAI_BASE_URL=https://api.openai.com/v1
# Reasoning effort for Stage 1 — only honored by reasoning-capable models
# (gpt-5.x family). Empty / unset = no reasoning param sent (back-compat with
# gpt-4.1-mini etc.). Allowed: minimal | low | medium | high.
OPENAI_REASONING_EFFORT=low

# ─── CLUSTERING (multi-signal similarity, PR-1) ─────────────────
# The clusterer combines several similarity signals to decide whether two
# items describe the same narrative. Replaces the old word-set Jaccard
# (which still kicks in as fallback if both OpenAI and image fetches fail).
#
# Signals & defaults (set in DB via admin panel; env vars below are for
# the underlying API/cache only):
#   - Embedding cosine (semantic):   weight 0.40 — see clusterWeightEmbedding
#   - Thumbnail dHash (visual):      weight 0.30 — see clusterWeightPhash
#   - Entity overlap (from nano):    weight 0.20 — see clusterWeightEntity
#   - Shared $TICKER bonus:          weight 0.10 — see clusterWeightTicker
#   - Merge threshold:               0.55         — see clusterSimThreshold
#   - Time-distance soft penalty:    24h          — see clusterTimePenaltyHours
#
# Setting CLUSTER_MULTI_SIGNAL=0 forces the legacy Jaccard path (useful as
# a panic switch). Default is enabled.
CLUSTER_MULTI_SIGNAL=1

# Embedding model — text-embedding-3-small is $0.02 / 1M tokens (effectively
# free at our volume). 1536-dim vectors, L2-normalised.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Per-batch HTTP timeout (embeddings normally <500ms; ceiling guards against
# stuck connections blocking the whole cycle).
EMBEDDING_TIMEOUT_MS=15000
# In-memory cache: text-hash → vector. Avoids paying twice for the same
# trend across consecutive cycles. TTL ≈ 2× scan interval.
EMBEDDING_CACHE_TTL_MS=300000
EMBEDDING_CACHE_CAP=1000

# Image hashing — used for "same meme" detection. Downloads the post's
# thumbnail (or imageUrl), resizes to 9×8 grayscale, dHashes to 64-bit.
# Hamming distance < 16 is the soft "same image" zone.
IMAGE_HASH_TIMEOUT_MS=5000
IMAGE_HASH_MAX_BYTES=2097152
IMAGE_HASH_CACHE_TTL_MS=900000
IMAGE_HASH_CACHE_CAP=500
IMAGE_HASH_CONCURRENCY=4

# ─── PRESTAGE (Stage 0): pre-Stage-1 enrichment ─────────────────
# PreStage runs BEFORE Stage 1 and never filters/scores — only enriches
# input data so Stage 1 has cleaner context. Two parallel sub-stages:
#   - Stage 0a: NanoClassifier (text enrichment via gpt-5.4-nano)
#   - Stage 0b: GeminiCaptioner (vision via OpenRouter → Gemini)
# Both fail gracefully — pipeline continues even if API unreachable.

# Stage 0a: NanoClassifier (uses existing OPENAI_API_KEY above)
OPENAI_NANO_MODEL=gpt-5.4-nano
STAGE0_NANO_MAX_BATCH=20

# Panic kill switch for nano. Set to 0 to FORCE-disable nano regardless of
# admin-panel state — useful when the admin UI is unreachable or you suspect
# nano is causing trouble. Default: enabled. Normal on/off should be done via
# the admin panel ("🎨 Stage 0 — PreStage" section), which flips a DB setting
# read at the start of each batch (no restart required).
STAGE0_NANO_ENABLED=1

# Stage 0b: GeminiCaptioner — two-provider failover.
#
#   PRIMARY:  Direct Google AI Studio (handles images + native video)
#   FALLBACK: OpenRouter (image-only — used when Google AI quota/geo/5xx fails)
#
# Why both: Google AI gives native video understanding (essential for TikTok
# meme videos where the joke is in the motion), and OpenRouter is the safety
# net so a Google quota wall or geo block doesn't kill our vision pipeline.
# Need at least ONE key for PreStage to be usable.

# ── PRIMARY: Direct Google AI Studio ──────────────────────────────────────
# Get key at https://aistudio.google.com/apikey (free tier ~1500 req/day,
# paid is very cheap on gemini-2.5-flash). Geo-restricted: works from US /
# most EU (Germany ok), blocked in RU/BY/etc.
GOOGLE_AI_API_KEY=your_google_ai_key_here
# Single model for both images and video — must be vision-capable. Use
# gemini-2.5-flash; gemini-3.x is not yet available on AI Studio public API.
GOOGLE_AI_MODEL=gemini-2.5-flash

# ── FALLBACK: OpenRouter ──────────────────────────────────────────────────
# Get key at https://openrouter.ai/keys (sk-or-v1-... format). Used ONLY
# when Google direct fails (quota, geo, 5xx). Image-only — OpenRouter does
# not reliably proxy video to Gemini, so video trends fall back to poster.
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_VISION_MODEL=google/gemini-2.5-flash
OPENROUTER_VISION_MODEL_FALLBACK=google/gemini-2.5-flash
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Failover cooldown ─────────────────────────────────────────────────────
# After N consecutive Google AI failures, skip Google for `cooldownMs` and
# go straight to OpenRouter. First success after cooldown resets the counter.
STAGE0_GOOGLE_COOLDOWN_FAILURES=3
STAGE0_GOOGLE_COOLDOWN_MS=300000

# ── Stage 0 size/duration caps ────────────────────────────────────────────
# Video duration cap. Gemini 2.5 charges ~1 frame/sec, so a 60s clip costs
# ~10-14K input tokens (~$0.004 per call). Keep generous — most TikToks are
# under 60s and longer ones rarely add narrative information.
STAGE0_VIDEO_MAX_SEC=60
# Size cap matched to duration cap. 60s TikTok is usually 5-15MB but can
# spike to 30MB at high bitrate; 40MB gives headroom without enabling abuse.
STAGE0_VIDEO_MAX_MB=40
STAGE0_IMAGE_MAX_MB=5
# Per-call timeout for Gemini (videos can be slow to upload). 60s video
# upload + processing on a slow connection can edge past 60s — 90s safe.
STAGE0_GEMINI_TIMEOUT_MS=90000
STAGE0_DOWNLOAD_TIMEOUT_MS=15000
# In-memory URL→caption cache TTL (avoids paying twice for the same image
# across consecutive cycles — typical TikTok thumbnails repeat)
STAGE0_GEMINI_CACHE_TTL_SEC=300

# ─── DASHBOARD ──────────────────────────────────────────────────

# Включить/отключить дашборд
DASHBOARD_ENABLED=true

# Port для дашборда (по умолчанию 7357)
DASHBOARD_PORT=7357

# Хост (0.0.0.0 = доступен везде, 127.0.0.1 = только локально)
DASHBOARD_HOST=0.0.0.0

# API ключ для защиты API (минимум 32 символа!)
# Генерировать: openssl rand -base64 32
DASHBOARD_API_KEY=<generate-with-openssl-rand-base64-32>

# Админ-панель (по умолчанию слушает только localhost)
ADMIN_PORT=8080
ADMIN_HOST=127.0.0.1
ADMIN_API_KEY=<generate-with-openssl-rand-base64-32>

# ─── DATABASE ───────────────────────────────────────────────────

# Путь к SQLite базе данных
DB_PATH=/data/catalyst.db

# ─── LOGGING ────────────────────────────────────────────────────

# Уровень логирования: debug, info, warn, error
LOG_LEVEL=info

# Файл логов
LOG_FILE=/logs/catalyst.log

# ─── SCANNING SETTINGS ──────────────────────────────────────────

# Интервал сканирования в минутах
SCAN_INTERVAL_MINUTES=15

# Глобальный дефолт порога алертов (0-100)
ALERT_THRESHOLD=60

# ─── EXTERNAL SERVICES (опционально) ────────────────────────────

# Discord webhook (если нужны алерты в Discord, УДАЛЕНО в v3.0)
# DISCORD_WEBHOOK_URL=

# Другие сервисы для интеграции
# SLACK_WEBHOOK_URL=
# PAGERDUTY_API_KEY=

# ===================================================================
# ИНСТРУКЦИИ ПО БЕЗОПАСНОСТИ
# ===================================================================
#
# 1. TELEGRAM_BOT_TOKEN:
#    - Получить в @BotFather
#    - Никогда не публиковать
#    - Рассматривать как пароль
#
# 2. HELIUS_API_KEY:
#    - Получить на helius.dev
#    - Необходим для Solana Pay (рекомендуется)
#    - Обеспечивает более быстрые запросы к RPC
#
# 3. SOLANA_MERCHANT_WALLET:
#    - Твой собственный Solana адрес
#    - На этот адрес будут приходить платежи
#    - Убедись что у тебя есть ключ от этого адреса
#
# 4. DASHBOARD_API_KEY:
#    - Генерировать сильный ключ: openssl rand -base64 32
#    - Использовать для защиты API
#    - Передавать через заголовок: X-API-Key
#
# 5. ОБЩИЕ ПРАВИЛА:
#    - Никогда не коммитить .env в Git
#    - Использовать разные ключи для dev/staging/production
#    - Регулярно ротировать ключи
#    - Ограничивать доступ к .env файлу (chmod 600)
#
# ===================================================================
